rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Global settings: Publicly readable, only admins can write
    match /settings/global {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.token.email == "g.singh200293@gmail.com";
    }
  }
}
